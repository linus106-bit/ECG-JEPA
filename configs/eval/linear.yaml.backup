attn_pooling: true
batch_size: 128
bias: false
checkpoint_interval: 500
crop_duration: 2.5
crop_stride: 1.25
dataset:
  data_dir: hf/ptb-xl
dropout: 0.0
early_stopping_patience: 15
epochs: 40
final_learning_rate: 0.001
frozen: true
gradient_clip: 1.0
layer_scale_eps: 0.0
learning_rate: 0.001
learning_rate_warmup_ratio: 0.0
opt_betas:
- 0.9
- 0.999
run:
  amp: bfloat16
  dataset_type: ecg
  encoder: results/pretrain/ViTB_capture24/m0.25_b10_p10/chkpt_30000.pt
  out_dir: results/finetune/ablation/ptb-xl/m0.25_b10_p10
  task: all
use_register: true
weight_decay: 0.1
